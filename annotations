//ARROW FUNCTION

/**Em React é comum o uso de Arrow Function para substituir 
as funções.*/

//EX FUNÇÕES NORMAIS:
function myFunction(){
    //code
}

//EX DE ARROW FUNCTION:
const myFnc = () => {
    //code
}
/**De forma reduzida, pode-se suprimir os parênteses
e o bloco de código, ficando da seguite forma:
const myFnc = parâmetro(s) => retorno da função*/
//EX: 
const myFnc = p1  => p1 * 2
console.log(myFnc(3))
// 6

