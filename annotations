// SPREAD OPERATOR

//EX IN ARRAY:
const numbers = [1,2,3];
const newNumbers = [...numbers, 4,5];
console.log(newNumbers);
//[1,2,3,4,5]

//EX IN OBJECT
const person = {
  name: 'marcos';
};

const newPerson = {
  ...person,
  age: 28
}
console.log(newPerson);
/**[object Object]{
  age: 28,
  name: 'marcos'
}
  */
