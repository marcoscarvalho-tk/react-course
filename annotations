//CLASSE PRORIEDADES E MÉTODOS

//############## ES6 ########################
//CLASSE PAI
class Human {
  constructor(){
    this.gender = 'male';
  }
  printGender(){
    console.log(this.gender);
  }
}
//CLASSE FILHO
class Person extends Human {
  constructor(){
    super(); // método para executar o construtor pai na classe Human
    this.name = 'marcos';
  }
  printName(){
    console.log(this.name);
  }
}
const person = new Person();
person.printName();
person.printGender();

//############# ES7 ###########################
//next generation of JS
//CLASSE PAI
class Human {
    gender = 'male';
  
    printGender = () => {
        console.log(this.gender);
  }
}
//CLASSE FILHO
class Person extends Human {
    name = 'marcos';
  
    printName = () => {
        console.log(this.name);
    }
}
const person = new Person();
person.printName();
person.printGender();

